{
  "manifest_version": 3,
  "name": "Vinted Hub Sync",
  "version": "2.0.0",
  "description": "Sync automático Vinted → dashboard privado",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "alarms"],
  "host_permissions": [
    "https://www.vinted.pt/*",
    "https://vinted.pt/*",
    "https://www.vinted.com/*",
    "https://vinted.com/*",
    "https://*.supabase.co/*",
    "https://vtw42b22dk-creator.github.io/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vinted Hub Sync"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.vinted.pt/*",
        "https://vinted.pt/*",
        "https://www.vinted.com/*",
        "https://vinted.com/*"
      ],
      "js": ["vinted-api.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://vtw42b22dk-creator.github.io/vinted-hub/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
